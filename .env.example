# RPC endpoint
COPILOT_RPC_URL=

# yellowstone gRPC endpoint
COPILOT_GRPC_URL=

# x-token for authenticated gRPC endpoints
COPILOT_GRPC_X_TOKEN=

# payer keypair (either a path to a Solana CLI keypair file or an inline base58 secret key)
COPILOT_KEYPAIR=/path/to/payer-keypair.json 

# Jito Block Engine base URL. Defaults to mainnet if unset. Regional mirrors:
#   https://amsterdam.mainnet.block-engine.jito.wtf/api/v1
#   https://ny.mainnet.block-engine.jito.wtf/api/v1   (etc.)
COPILOT_BLOCK_ENGINE=https://mainnet.block-engine.jito.wtf/api/v1

# Model the retry agent uses. Defaults to claude-sonnet-4-6 if unset.
COPILOT_MODEL=

# error | warn | info | debug | trace
COPILOT_LOG=info

# The agent's Claude credential is inherited from your Claude Code session and
# is normally already present in the environment, so you should not need to set it
# here. Only uncomment if you are running Copilot outside an authenticated
# session and want to supply a key explicitly.
# ANTHROPIC_API_KEY=